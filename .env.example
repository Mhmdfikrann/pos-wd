# Wanna Dimsum POS — environment template. Copy to .env and fill in.

# SQLite database path (better-sqlite3)
DATABASE_URL=./data/pos.db

# better-auth (PRD 13.3). Secret must be >= 32 chars:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000
